# Version control
.git
.github

# JS/PHP dependencies (rebuilt inside Docker)
node_modules
vendor

# Local environment config
.env
.env.backup
.env.production

# Laravel runtime files (created at container startup)
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*

# Built assets (rebuilt inside Docker)
public/build
public/hot

# SQLite database (created at container startup via migrate)
database/database.sqlite

# Dev/test tooling
tests
phpunit.xml
pint.json
eslint.config.js
.editorconfig

# Docs
README.md
*.md

# Docker compose / local tooling (not needed inside image)
docker-compose*
